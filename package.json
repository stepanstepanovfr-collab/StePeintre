{
  "name": "stepeintre",
  "version": "1.0.0",
  "private": true,
  "description": "Site vitrine premium StePeintre.",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md,yml}\"",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:html": "htmlhint \"index.html\"",
    "lint:js": "eslint script.js playwright.config.js tests/**/*.js",
    "a11y": "start-server-and-test serve http://127.0.0.1:4173 \"pa11y-ci --config .pa11yci.js\"",
    "quality": "npm run format:check && npm run lint && npm test && npm run a11y",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "serve": "npx http-server . -p 4173 -a 127.0.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "htmlhint": "^1.9.2",
    "http-server": "^14.1.1",
    "pa11y-ci": "^4.1.1",
    "prettier": "^3.6.0",
    "start-server-and-test": "^3.0.11",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
