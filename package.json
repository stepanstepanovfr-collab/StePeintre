{
  "name": "stepeintre",
  "version": "1.0.0",
  "private": true,
  "description": "Site vitrine premium StePeintre.",
  "scripts": {
    "dev": "next dev -p 4173 -H 127.0.0.1",
    "build": "next build",
    "start": "next start -p 4173 -H 127.0.0.1",
    "serve": "next dev -p 4173 -H 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,css,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,css,json,md,yml}\"",
    "lint": "npm run lint:js && npm run lint:css && npm run typecheck",
    "lint:css": "stylelint \"app/**/*.css\"",
    "lint:js": "eslint app components data lib playwright.config.js tests/**/*.js",
    "a11y": "start-server-and-test serve http://127.0.0.1:4173 \"pa11y-ci --config .pa11yci.js\"",
    "quality": "npm run format:check && npm run lint && npm test && npm run a11y && npm run build",
    "test": "playwright test",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.53.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "htmlhint": "^1.9.2",
    "http-server": "^14.1.1",
    "pa11y-ci": "^4.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.6.0",
    "start-server-and-test": "^3.0.11",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
